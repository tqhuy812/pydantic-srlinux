      "neighbor": [
        {
          "peer_address": "192.168.99.2",
          "peer_as": 65002,
          "peer_group": "client"
        }
      ]
    },
    "bgp_vpn": {
      "bgp_instance": [
        {
          "id": 1,
          "route_target": {
            "export_rt": "target:65001:2",
            "import_rt": "target:65001:2"
          }
        }
      ]
    }
  }
}